{
  "name": "bitwarden-check",
  "version": "1.0.0",
  "description": "CLI tool to audit Bitwarden vault items.",
  "author": {
    "name": "Cyril Jacquesson",
    "email": "cyril@jacquesson.me"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "inquirer": "^14.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
